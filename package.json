{
  "name": "make-pwa",
  "version": "0.1.0",
  "description": "Drop-in web utilities: PWA install banner, reconnecting WebSocket-RPC client.",
  "type": "module",
  "license": "MIT",
  "repository": "github:misrab/web-kit",
  "workspaces": [
    "packages/*"
  ],
  "main": "./packages/pwa/dist/index.js",
  "types": "./packages/pwa/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/pwa/dist/index.d.ts",
      "default": "./packages/pwa/dist/index.js"
    },
    "./ws-rpc": {
      "types": "./packages/ws-rpc/dist/index.d.ts",
      "default": "./packages/ws-rpc/dist/index.js"
    }
  },
  "bin": {
    "make-pwa": "./packages/pwa/dist/cli.js"
  },
  "scripts": {
    "build": "npm run build -w @misrab/pwa && npm run build -w @misrab/ws-rpc",
    "prepare": "npm run build"
  }
}
